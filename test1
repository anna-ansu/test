            Worker_Int["<b>Prefect Worker</b><br/>(Internal Pool)"]
            LLM["Локальная LLM / DB"]
        end
    end

    subgraph External_Cloud ["Внешние ВМ (Edge / DMZ)"]
        subgraph VM_1 ["Virtual Machine 1 (Node B)"]
            Worker_Edge_1["<b>Prefect Worker</b><br/>(Edge Pool)"]
        end
        
        subgraph VM_2 ["Virtual Machine 2 (Node C)"]
            Worker_Edge_2["<b>Prefect Worker</b><br/>(Edge Pool)"]
        end
    end

    %% Потоки управления и кода
    Server -.->|Назначает задачи| Worker_Int
    Server -.->|Назначает задачи| Worker_Edge_1
    Server -.->|Назначает задачи| Worker_Edge_2

    Worker_Edge_1 ==>|1. git clone| Repo
    Worker_Edge_2 ==>|1. git clone| Repo
    Worker_Int ==>|1. git clone| Repo

    %% Потоки данных
    Worker_Edge_1 -->|2. scraping| External_API((External API))
    Worker_Edge_2 -->|2. scraping| External_API
    
    Worker_Edge_1 -.->|3. upload raw data| Storage[(S3 / Raw Data Storage)]
    Worker_Edge_2 -.->|3. upload raw data| Storage
    
    Storage -.->|4. read raw| Worker_Int
    Worker_Int -->|5. clean & enrich| LLM
``` 
 

