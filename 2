CREATE OR REPLACE TRIGGER TRIGGER_TABLE_NAME
BEFORE INSERT ON TABLE_NAME
FOR EACH ROW
BEGIN
  IF INSERTING AND :NEW.ID IS NULL THEN
    SELECT TABLE_NAME.NEXTVAL INTO :NEW.ID FROM DUAL;
  END IF;
END;


